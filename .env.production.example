# ===================================================================
# Variáveis de ambiente PRODUÇÃO (EasyPanel)
# ===================================================================
# Copie cada uma destas no painel do EasyPanel → Environment Variables
# do serviço `agente`.
#
# NUNCA commite o arquivo .env real com valores reais no Git.
# Esse arquivo aqui é só template — sem valores sensíveis.
# ===================================================================

# ---- LLM provider ----
LLM_PROVIDER=openai

# ---- OpenAI (Responses API + Whisper) ----
OPENAI_API_KEY=sk-proj-COLE_AQUI
OPENAI_MODEL=gpt-4.1-mini

# ---- Claude (fallback opcional) ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ---- uazapi (WhatsApp) ----
UAZAPI_BASE=https://liaautomacoes.uazapi.com
UAZAPI_TOKEN=COLE_AQUI
UAZAPI_WEBHOOK_SECRET=

# ---- GoHighLevel (CRM) ----
GHL_API_TOKEN=
GHL_LOCATION_ID=
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_WEBHOOK_SECRET=
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_QUALIFIED=
GHL_PIPELINE_STAGE_HANDOFF=

# ---- Servidor ----
PORT=3333
NODE_ENV=production
LOG_LEVEL=info

# IMPORTANTE: troque pelo domínio público que o EasyPanel atribuir ao DASHBOARD
# Ex: https://lcsdr-dashboard.SEU-EASYPANEL.easypanel.host
# Mesma URL que será o webhook do uazapi: <PUBLIC_URL>/webhook/uazapi
PUBLIC_URL=https://SEU-DOMINIO.easypanel.host
DASHBOARD_ORIGIN=https://SEU-DOMINIO.easypanel.host

# ---- Dashboard auth ----
# Gere uma string aleatória bem longa (32+ chars). NUNCA reutilize entre projetos.
JWT_SECRET=GERE_UM_VALOR_ALEATORIO_LONGO_AQUI

# ---- Comportamento da Lila ----
FOLLOWUP_SILENCE_MINUTES=60
MAX_ATTACHMENT_KB=200
MAX_MESSAGES_PER_CONVERSATION_PER_DAY=40
