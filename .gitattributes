# Força LF em scripts shell e arquivos Docker pra não quebrar em containers Linux
# (Windows tende a converter pra CRLF, que faz `#!/bin/sh\r` virar binário inválido)

*.sh             text eol=lf
Dockerfile       text eol=lf
Dockerfile.*     text eol=lf
*.conf           text eol=lf
*.conf.template  text eol=lf
docker-entrypoint.sh text eol=lf
