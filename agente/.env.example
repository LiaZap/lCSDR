# ==== LLM provider ====
# 'openai' (default, mais barato, gpt-4.1-mini via Responses API)
# 'anthropic' (Claude Sonnet 4.6 via Messages API)
# Se vazio: auto-detecta com base nas chaves preenchidas abaixo.
LLM_PROVIDER=openai

# ==== OpenAI (Responses API + Whisper) ====
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# ==== Claude (Anthropic) — fallback opcional ====
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ==== uazapi (WhatsApp não-oficial brasileiro) ====
# Se preenchido, a Lila ENVIA via uazapi. Senão, usa GHL como fallback.
UAZAPI_BASE=https://liaautomacoes.uazapi.com
UAZAPI_TOKEN=
# Segredo opcional pro webhook do uazapi (header X-Webhook-Secret)
UAZAPI_WEBHOOK_SECRET=

# ==== GoHighLevel (GHL) ====
# Token de acesso à API v2 (Private Integration Token — começa com `pit-`)
GHL_API_TOKEN=pit-...
GHL_LOCATION_ID=
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# Segredo do webhook para validar HMAC das chamadas GHL (opcional — se vazio, aceita sem assinar)
GHL_WEBHOOK_SECRET=

# Pipeline/stage onde a Iara move o lead quando qualifica (rode `npm run ghl:bootstrap` pra descobrir os IDs)
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_QUALIFIED=
GHL_PIPELINE_STAGE_HANDOFF=

# ==== OpenAI (usado só para Whisper — transcrição de áudio) ====
OPENAI_API_KEY=sk-...

# ==== Servidor ====
PORT=3333
NODE_ENV=development
LOG_LEVEL=info
PUBLIC_URL=http://localhost:3333

# ==== Dashboard ====
JWT_SECRET=troque-por-uma-string-aleatoria-bem-longa
DASHBOARD_ORIGIN=http://localhost:5173

# ==== Comportamento do agente ====
# Tempo em minutos que a IA espera antes de retomar conversa quando SDR ou lead fica em silêncio
FOLLOWUP_SILENCE_MINUTES=60
# Limite de tamanho de arquivo (KB) que a IA aceita analisar (acima disso, encaminha para SDR)
MAX_ATTACHMENT_KB=200
# Limite diário de mensagens por conversa (proteção de custo)
MAX_MESSAGES_PER_CONVERSATION_PER_DAY=40
